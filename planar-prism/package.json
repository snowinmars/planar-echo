{
  "name": "@planar/prism",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/snowinmars/planar-echo.git"
  },
  "version": "0.0.1",
  "description": "Typescript pipe to transform officially bought InfinityEngine binaries (f.e., Planescape:Torment) to json and ghost",
  "author": "snowinmars",
  "scripts": {
    "build": "tsc && tsc-alias",
    "build-ghost": "yarn build-ghost-creatures && yarn build-ghost-dialogues && yarn build-ghost-items",
    "build-ghost-creatures": "node ./src/dev/build-ghost-subdirectory.cjs creatures",
    "build-ghost-dialogues": "node ./src/dev/build-ghost-subdirectory.cjs dialogues",
    "build-ghost-items": "node ./src/dev/build-ghost-subdirectory.cjs items",
    "clean": "node src/dev/clean.js",
    "start": "yarn build && node dist/index.js",
    "lint": "eslint",
    "test": "mocha"
  },
  "dependencies": {
    "@planar/shared": "workspace:*",
    "rxjs": "^7.8.2",
    "winston": "^3.19.0"
  },
  "_devD": {
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/parser": "^8.57.1",
    "chai": "^6.2.2",
    "cpy-cli": "^7.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.1.0",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "tsc": "^2.0.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.22.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "main": "./src/index.ts"
}
