{
  "name": "@planar/prism",
  "type": "module",
  "private": false,
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/snowinmars/planar-echo.git"
  },
  "version": "0.0.1",
  "description": "Typescript pipe to transform officially bought InfinityEngine binaries (f.e., Planescape:Torment) to json and ghost",
  "author": "snowinmars",
  "scripts": {
    "copy": "cpy src/ghost/dialogueEngine/_*.ts ../planar-ghost/ghost/dialogues",
    "compile": "tsc && tsc-alias",
    "compile-ghost": "npx esbuild ../planar-ghost/ghost/dialogues/*.ts --outdir=../planar-ghost/ghost/dialogues/dist --platform=node --target=node16 --bundle=true --minify --charset=utf8 --format=iife --global-name=ghost --banner:js=\"\\\"use strict\\\";\" --footer:js=\"ghost.default\"",
    "start": "yarn compile && node dist/index.js && yarn copy",
    "lint": "eslint",
    "test": "node dist/test.js"
  },
  "dependencies": {
    "rxjs": "^7.8.2",
    "winston": "^3.19.0"
  },
  "_devD": {
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@planar/shared": "file:../planar-shared",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/node": "^25.3.0",
    "@typescript-eslint/parser": "^8.56.1",
    "cpy-cli": "^7.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.0.1",
    "tsc": "^2.0.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "main": "./src/index.ts"
}
