{
    "name": "planar-shell",
    "version": "0.0.1",
    "description": "React engine to run planar-ghost artifact from planar-prism flow",
    "main": "./index.html",
    "author": "snowinmars",
    "license": "GPL-3.0-or-later",
    "private": false,
    "type": "module",
    "scripts": {
        "start": "vite",
        "build": "tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint . --ext ts,tsx --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,scss,css,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,css,json}\"",
        "preview": "vite preview",
        "_test_comment": "get examples from https://github.com/SingleDraw/react-vite/blob/main/src/components/Counter/Counter.test.tsx",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "prepare": "husky install"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.8",
        "@mui/material": "^7.3.8",
        "axios": "^1.13.6",
        "clsx": "^2.1.1",
        "i18next": "^25.8.18",
        "i18next-browser-languagedetector": "^8.2.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-i18next": "^16.5.8",
        "react-router-dom": "^7.13.1",
        "rxjs": "^7.8.2",
        "use-sync-external-store": "^1.6.0",
        "winston": "^3.19.0",
        "zustand": "^5.0.11",
        "zustand-di": "^0.0.16"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@planar/shared": "file:../planar-shared",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.0",
        "@vitest/ui": "4.0.18",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "sass": "^1.98.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^8.0.1",
        "vite-plugin-svgr": "^4.5.0",
        "vitest": "^4.1.0"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{scss,css,json,md}": [
            "prettier --write"
        ]
    }
}
